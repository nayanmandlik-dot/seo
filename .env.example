# Backend env vars (used by backend/server.js and friends)
# Copy this file to backend/.env for local dev. In production these are set in
# the Render dashboard.

PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Google PageSpeed Insights API key (required for Page Speed / CWV module)
# Get one free at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Optional: Google Safe Browsing
SAFE_BROWSING_API_KEY=

# Redis is optional — the queue falls back to an in-memory implementation.
# Set DISABLE_REDIS=1 to skip the Redis connection attempt entirely.
DISABLE_REDIS=1
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Where to write generated reports / exports. On Render free tier the disk is
# ephemeral; use /tmp paths so writes succeed (files are lost on restart).
REPORTS_DIR=reports
EXPORTS_DIR=exports

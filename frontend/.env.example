# Frontend env vars (read by Vite at build time)
#
# Local dev: leave VITE_API_BASE empty — vite.config.js proxies /api to
# http://localhost:4000 automatically.
#
# Production (Vercel): set VITE_API_BASE in the Vercel project settings to your
# deployed backend URL, including the /api suffix. Example:
#   VITE_API_BASE=https://seo-audit-backend.onrender.com/api

VITE_API_BASE=

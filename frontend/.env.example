# Copy to .env (gitignored) and fill in. Read by Vite at build time.
#
# VITE_API_URL — base URL of the backend (no trailing /api).
#   Production: https://seo-p307.onrender.com
#   Local dev:  leave empty so calls are relative and the Vite proxy
#               in vite.config.js forwards /api → http://localhost:4000

VITE_API_URL=
